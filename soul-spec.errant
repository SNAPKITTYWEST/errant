-- ════════════════════════════════════════════════════════════════
-- ERRANT WORM SEALING
-- ════════════════════════════════════════════════════════════════

: lin cap seal ⊸ lin data ⊸ lin sealed
seal_data cap data = seal cap data

: lin sealed ⊸ lin hash
hash_sealed sealed = hash sealed

: lin cap sign ⊸ lin hash ⊸ lin signature
sign_hash cap hash = sign cap hash

-- ════════════════════════════════════════════════════════════════
-- ERRANT EXECUTION — Stack-based
-- ════════════════════════════════════════════════════════════════

-- Push value onto stack
: lin a ⊸ lin Stack ⊸ lin Stack
push val stack = val : stack

-- Pop value from stack
: lin Stack ⊸ lin (a, Stack)
pop (x:xs) = (x, xs)

-- Apply linear function
: lin (a ⊸ b) ⊸ lin a ⊸ lin b
apply f x = f x

-- Call function frame
: lin Frame ⊸ lin Result
call frame = execute frame

-- Return from call
: lin Result ⊸ lin Stack
return result = [result]

